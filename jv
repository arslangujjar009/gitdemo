const spiderMan = document.getElementById('spider-man');
const building1 = document.getElementById('building1');
const building2 = document.getElementById('building2');
const ground = document.getElementById('ground');
let gameContainer = document.getElementById('game-container');

let swingSpeed = 3; // Speed of Spider-Man's swing
let isSwinging = false;
let currentAngle = 0;

// Move Spider-Man
function moveSpiderMan() {
  if (isSwinging) {
    currentAngle += swingSpeed;
    spiderMan.style.transform = `rotate(${currentAngle}deg)`;
    let spiderPos = parseInt(window.getComputedStyle(spiderMan).bottom, 10);
    if (spiderPos <= 0) {
      endGame();
    }
  }
}

// Start the swing action
function startSwinging() {
  isSwinging = true;
  document.addEventListener('keydown', (e) => {
    if (e.key === ' ') {
      // Trigger Spider-Man's swing
      swingSpeed = 5;
    }
  });
}

// End the game
function endGame() {
  alert("Game Over!");
  resetGame();
}

// Reset the game
function resetGame() {
  spiderMan.style.bottom = '100px';
  spiderMan.style.left = '100px';
  currentAngle = 0;
  isSwinging = false;
}

// Move Spider-Man left and right
document.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowRight') {
    let left = parseInt(window.getComputedStyle(spiderMan).left, 10);
    if (left < gameContainer.offsetWidth - spiderMan.offsetWidth) {
      spiderMan.style.left = left + 10 + 'px';
    }
  } else if (e.key === 'ArrowLeft') {
    let left = parseInt(window.getComputedStyle(spiderMan).left, 10);
    if (left > 0) {
      spiderMan.style.left = left - 10 + 'px';
    }
  }
});

// Start the game when the user presses a key
document.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    startSwinging();
  }
});

// Game loop
setInterval(() => {
  moveSpiderMan();
}, 20);