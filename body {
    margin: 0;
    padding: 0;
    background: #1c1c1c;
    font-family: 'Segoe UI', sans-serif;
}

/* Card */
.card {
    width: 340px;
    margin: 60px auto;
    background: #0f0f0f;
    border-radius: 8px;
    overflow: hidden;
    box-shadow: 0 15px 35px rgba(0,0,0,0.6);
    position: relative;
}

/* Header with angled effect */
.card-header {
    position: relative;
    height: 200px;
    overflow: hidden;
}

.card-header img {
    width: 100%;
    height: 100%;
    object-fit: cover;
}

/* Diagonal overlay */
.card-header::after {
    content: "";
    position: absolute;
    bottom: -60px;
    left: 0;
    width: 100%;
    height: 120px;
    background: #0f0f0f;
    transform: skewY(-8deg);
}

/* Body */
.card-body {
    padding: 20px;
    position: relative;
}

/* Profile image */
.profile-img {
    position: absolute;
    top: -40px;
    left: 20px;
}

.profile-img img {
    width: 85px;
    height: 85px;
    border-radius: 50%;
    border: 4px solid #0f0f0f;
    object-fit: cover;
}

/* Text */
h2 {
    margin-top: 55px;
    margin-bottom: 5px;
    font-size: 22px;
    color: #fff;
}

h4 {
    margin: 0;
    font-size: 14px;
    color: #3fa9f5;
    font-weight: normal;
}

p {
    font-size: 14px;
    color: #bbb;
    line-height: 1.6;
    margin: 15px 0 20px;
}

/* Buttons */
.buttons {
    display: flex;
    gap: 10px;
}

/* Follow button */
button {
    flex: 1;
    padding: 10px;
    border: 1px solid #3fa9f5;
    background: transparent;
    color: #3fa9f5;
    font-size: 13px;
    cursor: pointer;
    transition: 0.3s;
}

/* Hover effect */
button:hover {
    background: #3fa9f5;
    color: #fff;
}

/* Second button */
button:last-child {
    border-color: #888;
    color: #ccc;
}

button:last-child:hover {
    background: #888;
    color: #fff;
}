body {
    margin: 0;
    padding: 0;
    background: #1c1c1c;
    font-family: 'Segoe UI', sans-serif;
}

/* Card */
.card {
    width: 340px;
    margin: 60px auto;
    background: #0f0f0f;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 15px 35px rgba(0,0,0,0.6);
    position: relative;
}

/* Header with angled effect */
.card-header {
    position: relative;
    height: 200px;
    overflow: hidden;
}

.card-header img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

/* Diagonal overlay */
.card-header::after {
    content: "";
    position: absolute;
    bottom: -60px;
    left: 0;
    width: 100%;
    height: 120px;
    background: #0f0f0f;
    transform: skewY(-8deg);
}

/* Body */
.card-body {
    padding: 20px;
    position: relative;
}

/* Profile image */
.profile-img {
    position: absolute;
    top: -40px;
    left: 20px;
}

.profile-img img {
    width: 85px;
    height: 85px;
    border-radius: 50%;
    border: 4px solid #0f0f0f;
    object-fit: cover;
}

/* Text */
h2 {
    margin-top: 55px;
    margin-bottom: 5px;
    font-size: 22px;
    color: #fff;
}

h4 {
    margin: 0;
    font-size: 14px;
    color: #3fa9f5;
    font-weight: normal;
}

p {
    font-size: 14px;
    color: #bbb;
    line-height: 1.6;
    margin: 15px 0 20px;
}

/* Buttons */
.buttons {
    display: flex;
    gap: 10px;
}

/* Follow button */
button {
    flex: 1;
    padding: 10px;
    border: 1px solid #3fa9f5;
    background: transparent;
    color: #3fa9f5;
    font-size: 13px;
    cursor: pointer;
    transition: 0.3s;
}

/* Hover effect */
button:hover {
    background: #3fa9f5;
    color: #fff;
}

/* Second button */
button:last-child {
    border-color: #888;
    color: #ccc;
}

button:last-child:hover {
    background: #888;
    color: #fff;
}